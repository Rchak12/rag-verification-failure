# REQUIRED: OpenAI API key for GPT-4o generation and rewriting
OPENAI_API_KEY=sk-proj-...

# GPT model to use (gpt-4o recommended for best results)
OPENAI_MODEL=gpt-4o

# Optional: HuggingFace token if using gated models
HF_TOKEN=hf_...

# Optional: set to "cpu" or "cuda" to override device detection
DEVICE=cpu

# Generation backend: "openai" (GPT-4o) or "stub" (rule-based, for testing only)
GENERATION_BACKEND=openai
